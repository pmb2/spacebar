# =============================================================================
# .dockerignore — Exclude unnecessary files from Docker build context
# =============================================================================

# === Dependencies ===
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# === Version control ===
.git
.gitignore
.gitattributes
.gitmodules
.github
.gitlab-ci.yml

# === Environment ===
.env
.env.*
!.env.example

# === IDE & Editor ===
.vscode
.idea
*.sublime-*
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# === Project build artifacts ===
# dist is built inside the Docker image, not copied from host
dist

# === Git hooks & tooling ===
.husky
.prettierrc
.eslintrc*
.eslintignore
.prettierignore
# tsconfig.tsbuildinfo is copied by Dockerfile before build

# === Tests ===
tests
test
__tests__
coverage
*.test.ts
*.spec.ts
*.test.js
*.spec.js

# === Documentation ===
docs
*.md
!README.md

# === Docker files (exclude from context — they're used directly) ===
Dockerfile
docker-compose*
.dockerignore

# === CI/CD ===
.circleci
.travis.yml
azure-pipelines.yml

# === OS files ===
.vagrant
.vagrant.d

# === Logs ===
logs
*.log

# config.json is needed by Dockerfile at build time
